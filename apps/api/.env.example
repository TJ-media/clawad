# 클로애드 API 로컬 개발용 환경변수 예시. 실제 .env는 커밋하지 않는다(.gitignore).
# 운영 비밀값은 시크릿 매니저로 주입한다 (CLAW-27).

PORT=3000

# PostgreSQL (docker-compose가 호스트 55432로 노출 — 기본 포트 충돌 회피)
DB_HOST=localhost
DB_PORT=55432
DB_USER=clawad
DB_PASSWORD=clawad_local_dev
DB_NAME=clawad

# Redis (refresh 토큰 allowlist). docker-compose가 호스트 56379로 노출
REDIS_HOST=localhost
REDIS_PORT=56379
# 논리 DB 인덱스(기본 0). e2e는 REDIS_DB=1 등 별도 인덱스를 써서 데모 데이터와 분리한다(CLAW-39).
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TLS=false

# 외부 관리형 PostgreSQL TLS 사용 시 true. 인증서 검증 해제는 로컬 진단 외 금지.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# 인증 토큰 서명 키. 32바이트 이상. 공개 fallback을 두지 않는다 (CLAW-18 §서명 키).
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_JWT_SECRET=

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# 웹 세션 refresh 쿠키 (CLAW-38). 웹 클라이언트는 refresh 토큰을 httpOnly 쿠키로 받는다.
# 운영은 HTTPS이므로 Secure=true 필수. 로컬 http 데모에서만 false로 둔다.
AUTH_COOKIE_SECURE=true
# lax(기본, 동일 사이트 권장) | strict | none(크로스사이트 배포 시, 반드시 Secure=true).
AUTH_COOKIE_SAMESITE=lax
# 쿠키 도메인(선택). 비우면 요청 호스트. 운영에서 api·web이 서브도메인이면 상위 도메인 지정.
AUTH_COOKIE_DOMAIN=

# serveToken 서명 키. 32바이트 이상 서버 전용 비밀값. 공개 fallback을 두지 않는다 (CLAW-18).
# 인증 토큰(AUTH_JWT_SECRET)과 반드시 다른 값을 쓴다.
SERVE_TOKEN_SECRET=

# 클릭 URL 서명 키. serveToken·인증 토큰 키와 반드시 다른 32바이트 이상 값.
CLICK_TOKEN_SECRET=

# 관리자 JWT 서명 키 (CLAW-27). 32바이트 이상. 인증·serveToken 키와도 다른 값.
ADMIN_JWT_SECRET=
ADMIN_TOKEN_TTL=30m

# 부트스트랩 SUPERADMIN. 관리자가 하나도 없을 때만 생성한다. 운영은 시크릿 매니저로 주입.
# 정적 관리 토큰(구 ADMIN_API_TOKEN)은 폐기됐다 — 관리자 로그인 JWT로 대체.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_ENABLED=true

# 운영 브라우저 origin. 운영에서는 HTTPS origin을 명시하고 와일드카드를 쓰지 않는다.
CORS_ORIGINS=

# ── 소셜 로그인 (CLAW-37) ──────────────────────────────────────────────
# 공개 사용자 로그인은 Google·Kakao·Naver 전용이다. 이메일/비밀번호·GitHub 공개 로그인은 비활성.
# client id/secret은 각 개발자 콘솔에서 발급해 시크릿 매니저로 주입한다(레포에 커밋 금지, CLAW-27).
# client id와 secret이 모두 설정된 공급자만 활성화된다 — 일부만 설정해도 서버는 기동된다.
SOCIAL_GOOGLE_CLIENT_ID=
SOCIAL_GOOGLE_CLIENT_SECRET=
SOCIAL_GOOGLE_ENABLED=true
# Kakao는 REST API 키가 client id다. 개발자 콘솔에서 OpenID Connect 활성화가 선행돼야 한다.
SOCIAL_KAKAO_CLIENT_ID=
SOCIAL_KAKAO_CLIENT_SECRET=
SOCIAL_KAKAO_ENABLED=true
SOCIAL_NAVER_CLIENT_ID=
SOCIAL_NAVER_CLIENT_SECRET=
SOCIAL_NAVER_ENABLED=true

# 공급자 콜백 redirect_uri 조립용 API base URL. 각 공급자 콘솔에 등록한 값과 반드시 일치해야 한다.
# 예: http://localhost:3000 → http://localhost:3000/v1/auth/social/google/callback
SOCIAL_CALLBACK_BASE_URL=http://localhost:3000
# 콜백 후 handoff code를 URL fragment로 받을 수 있는 return target allowlist(쉼표 구분, 정확한 origin).
# 127.0.0.1 loopback(CLI clawad:login)은 이와 별개로 항상 허용된다. 임의 외부 URL은 거절된다.
SOCIAL_RETURN_ALLOWLIST=http://localhost:3111
SOCIAL_METRICS_RETENTION_DAYS=30
# state / 1회성 handoff code의 TTL(초). 미설정 시 각각 600 / 120.
SOCIAL_STATE_TTL_SECONDS=600
SOCIAL_HANDOFF_TTL_SECONDS=120
