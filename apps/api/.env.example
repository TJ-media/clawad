# 클로애드 API 로컬 개발용 환경변수 예시. 실제 .env는 커밋하지 않는다(.gitignore).
# 운영 비밀값은 시크릿 매니저로 주입한다 (CLAW-27).

PORT=3000

# PostgreSQL (docker-compose가 호스트 55432로 노출 — 기본 포트 충돌 회피)
DB_HOST=localhost
DB_PORT=55432
DB_USER=clawad
DB_PASSWORD=clawad_local_dev
DB_NAME=clawad

# Redis (refresh 토큰 allowlist). docker-compose가 호스트 56379로 노출
REDIS_HOST=localhost
REDIS_PORT=56379
# 논리 DB 인덱스(기본 0). e2e는 REDIS_DB=1 등 별도 인덱스를 써서 데모 데이터와 분리한다(CLAW-39).
REDIS_DB=0

# 인증 토큰 서명 키. 32바이트 이상. 공개 fallback을 두지 않는다 (CLAW-18 §서명 키).
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_JWT_SECRET=

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# serveToken 서명 키. 32바이트 이상 서버 전용 비밀값. 공개 fallback을 두지 않는다 (CLAW-18).
# 인증 토큰(AUTH_JWT_SECRET)과 반드시 다른 값을 쓴다.
SERVE_TOKEN_SECRET=

# 관리자 JWT 서명 키 (CLAW-27). 32바이트 이상. 인증·serveToken 키와도 다른 값.
ADMIN_JWT_SECRET=
ADMIN_TOKEN_TTL=30m

# 부트스트랩 SUPERADMIN. 관리자가 하나도 없을 때만 생성한다. 운영은 시크릿 매니저로 주입.
# 정적 관리 토큰(구 ADMIN_API_TOKEN)은 폐기됐다 — 관리자 로그인 JWT로 대체.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
