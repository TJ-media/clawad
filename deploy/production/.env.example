# 실제 값은 저장소에 커밋하지 말고 배포 환경의 시크릿 매니저에서 주입한다.
API_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com
# 두 값은 반드시 실제 40자리 소문자 Git commit SHA로 교체한다.
RELEASE_SHA=0000000000000000000000000000000000000000
ROLLBACK_SHA=1111111111111111111111111111111111111111
BACKUP_DIR=./backups
PROMETHEUS_RETENTION=30d
OBSERVABILITY_WINDOW_MINUTES=15
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=clawad-admin

# 각 파일은 비밀 관리자에서 호스트에 0600으로 배치한다. 파일 내용은 한 줄짜리 비밀값이다.
MONITORING_TOKEN_FILE=/run/clawad-secrets/monitoring-token
ALERT_WEBHOOK_URL_FILE=/run/clawad-secrets/alert-webhook-url
GRAFANA_ADMIN_PASSWORD_FILE=/run/clawad-secrets/grafana-admin-password

DB_USER=clawad
DB_PASSWORD=
DB_NAME=clawad
REDIS_PASSWORD=

AUTH_JWT_SECRET=
SERVE_TOKEN_SECRET=
CLICK_TOKEN_SECRET=
ADMIN_JWT_SECRET=

# 최초 관리자 생성 시에만 true와 아래 두 값을 주입한다. 생성 직후 false로 바꾸고 비밀번호 시크릿을 제거한다.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

CORS_ORIGINS=https://app.example.com
SOCIAL_RETURN_ALLOWLIST=https://app.example.com
SOCIAL_METRICS_RETENTION_DAYS=30
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=.example.com

SOCIAL_GOOGLE_CLIENT_ID=
SOCIAL_GOOGLE_CLIENT_SECRET=
SOCIAL_GOOGLE_ENABLED=true
SOCIAL_KAKAO_CLIENT_ID=
SOCIAL_KAKAO_CLIENT_SECRET=
SOCIAL_KAKAO_ENABLED=true
SOCIAL_NAVER_CLIENT_ID=
SOCIAL_NAVER_CLIENT_SECRET=
SOCIAL_NAVER_ENABLED=true
LEGAL_TERMS_VERSION=v1
LEGAL_TERMS_URL=https://example.com/legal/terms
LEGAL_TERMS_EFFECTIVE_AT=2026-07-14
LEGAL_PRIVACY_VERSION=v1
LEGAL_PRIVACY_URL=https://example.com/legal/privacy
LEGAL_PRIVACY_EFFECTIVE_AT=2026-07-14
LEGAL_PRIVACY_CONTACT_URL=https://example.com/privacy-contact
LEGAL_REMOVAL_GUIDE_URL=https://example.com/uninstall
