# 실제 값은 저장소에 커밋하지 말고 배포 환경의 시크릿 매니저에서 주입한다.
API_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com
IMAGE_TAG=0.1.0
BACKUP_DIR=./backups

DB_USER=clawad
DB_PASSWORD=
DB_NAME=clawad
REDIS_PASSWORD=

AUTH_JWT_SECRET=
SERVE_TOKEN_SECRET=
CLICK_TOKEN_SECRET=
ADMIN_JWT_SECRET=

# 최초 관리자 생성 시에만 true와 아래 두 값을 주입한다. 생성 직후 false로 바꾸고 비밀번호 시크릿을 제거한다.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

CORS_ORIGINS=https://app.example.com
SOCIAL_RETURN_ALLOWLIST=https://app.example.com
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=.example.com

SOCIAL_GOOGLE_CLIENT_ID=
SOCIAL_GOOGLE_CLIENT_SECRET=
SOCIAL_KAKAO_CLIENT_ID=
SOCIAL_KAKAO_CLIENT_SECRET=
SOCIAL_NAVER_CLIENT_ID=
