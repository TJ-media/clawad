# 실제 값은 저장소에 커밋하지 말고 배포 환경의 시크릿 매니저에서 주입한다.
API_DOMAIN=api.example.com
WEB_DOMAIN=app.example.com
PUBLIC_RELEASE_STAGE=alpha
ACME_EMAIL=ops@example.com
# 두 값은 반드시 실제 40자리 소문자 Git commit SHA로 교체한다.
RELEASE_SHA=0000000000000000000000000000000000000000
ROLLBACK_SHA=1111111111111111111111111111111111111111
BACKUP_DIR=./backups
# 외부 백업 복제 (CLAW-75). BACKUP_S3_BUCKET을 비우면 로컬 백업만 수행한다.
# 자격증명은 EC2 인스턴스 역할(IAM)로 제공하며 키를 여기에 넣지 않는다.
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=postgres
# 저장 암호화: AES256(SSE-S3) 기본. 고객 관리 키가 필요하면 aws:kms + BACKUP_S3_SSE_KMS_KEY_ID.
BACKUP_S3_SSE=AES256
BACKUP_S3_SSE_KMS_KEY_ID=
# 백업 성공 메트릭을 남길 호스트 디렉토리(node-exporter textfile collector가 읽는다).
NODE_EXPORTER_TEXTFILE_DIR=./textfile
# 법무 승인된 공개본만 두는 호스트 디렉터리. 저장소의 docs/legal 초안은 사용하지 않는다.
LEGAL_PUBLIC_DIR=/run/clawad-public-legal
PROMETHEUS_RETENTION=30d
OBSERVABILITY_WINDOW_MINUTES=15
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=clawad-admin

# 각 파일은 비밀 관리자에서 호스트에 0600으로 배치한다. 파일 내용은 한 줄짜리 비밀값이다.
MONITORING_TOKEN_FILE=/run/clawad-secrets/monitoring-token
ALERT_WEBHOOK_URL_FILE=/run/clawad-secrets/alert-webhook-url
GRAFANA_ADMIN_PASSWORD_FILE=/run/clawad-secrets/grafana-admin-password

DB_USER=clawad
DB_PASSWORD=
DB_NAME=clawad
REDIS_PASSWORD=

AUTH_JWT_SECRET=
SERVE_TOKEN_SECRET=
CLICK_TOKEN_SECRET=
ADMIN_JWT_SECRET=

# 최초 관리자 생성 시에만 true와 아래 두 값을 주입한다. 생성 직후 false로 바꾸고 비밀번호 시크릿을 제거한다.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

CORS_ORIGINS=https://app.example.com
SOCIAL_RETURN_ALLOWLIST=https://app.example.com
SOCIAL_METRICS_RETENTION_DAYS=30
AUTH_COOKIE_SAMESITE=lax
# host-only 쿠키를 유지한다. webOrigin의 same-origin /v1 프록시에서 발급된다.
AUTH_COOKIE_DOMAIN=

SOCIAL_GOOGLE_CLIENT_ID=
SOCIAL_GOOGLE_CLIENT_SECRET=
SOCIAL_GOOGLE_ENABLED=true
SOCIAL_KAKAO_CLIENT_ID=
SOCIAL_KAKAO_CLIENT_SECRET=
SOCIAL_KAKAO_ENABLED=true
SOCIAL_NAVER_CLIENT_ID=
SOCIAL_NAVER_CLIENT_SECRET=
SOCIAL_NAVER_ENABLED=true
LEGAL_TERMS_VERSION=v1
LEGAL_TERMS_URL=https://app.example.com/legal/terms-v1.html
LEGAL_TERMS_EFFECTIVE_AT=2026-07-14
LEGAL_PRIVACY_VERSION=v2
LEGAL_PRIVACY_URL=https://app.example.com/legal/privacy-v2.html
LEGAL_PRIVACY_EFFECTIVE_AT=2026-07-22
LEGAL_PRIVACY_CONTACT_URL=https://app.example.com/legal/privacy-contact.html
LEGAL_REMOVAL_GUIDE_URL=https://app.example.com/legal/removal-guide.html
# TEST 캠페인 운영 리허설 창에서만 true. 평상시는 false로 유지한다.
CLAWAD_TEST_REHEARSAL_ENABLED=false
CLAWAD_TEST_REHEARSAL_USER_IDS=
